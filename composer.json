{
	"name": "cosray/cms",
	"description": "Cosray content management system and framework",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@cosray.dev"
		}
	],
	"homepage": "https://cosray.dev",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require": {
		"php": "^8.5",
		"ext-pgsql": "*",
		"ext-gd": "*",
		"ext-intl": "*",
		"ext-curl": "*",
		"ext-dom": "*",
		"ext-sodium": "*",
		"ext-xml": "*",
		"celemas/boiler": "^0.4.0",
		"celemas/core": "^0.4.0",
		"celemas/quma": "^0.2.0",
		"celemas/session": "^0.2.0",
		"celemas/sire": "^0.4.0",
		"gumlet/php-image-resize": "2.0.*",
		"hidehalo/nanoid-php": "^2",
		"psr/log": "^3.0",
		"vlucas/phpdotenv": "^5.6"
	},
	"require-dev": {
		"celemas/dev": "^4.2",
		"filp/whoops": "^2.15",
		"laminas/laminas-diactoros": "^3"
	},
	"suggest": {
		"filp/whoops": "Enables pretty debug error pages in debug mode."
	},
	"autoload": {
		"psr-4": {
			"Cosray\\": "src"
		},
		"files": [
			"src/Functions.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Cosray\\Tests\\": "tests"
		}
	},
	"scripts": {
		"test": "@php vendor/bin/phpunit --testdox --no-coverage --colors=always",
		"docs:format": "npx prettier@3.6.2 --write --config docs/.prettierrc README.md CHANGELOG.md",
		"docs:lint": "npx markdownlint-cli2@0.22.1 --config vendor/celemas/dev/config/markdownlint.jsonc README.md CHANGELOG.md",
		"lint": [
			"@php vendor/bin/mago fmt --check",
			"@php vendor/bin/mago lint"
		],
		"coverage:test": "@php -d xdebug.mode=coverage vendor/bin/phpunit --testdox --colors=always",
		"coverage:analyze": "@php vendor/bin/coverlyzer .coverage/coverage.php",
		"coverage": [
			"@coverage:test",
			"@coverage:analyze"
		],
		"license:lint": "if command -v reuse >/dev/null 2>&1; then reuse lint; else echo 'Skipping REUSE lint: reuse not installed'; fi",
		"ci": [
			"@lint",
			"@coverage",
			"@license:lint",
			"@docs:lint"
		]
	}
}
