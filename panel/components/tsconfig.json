{
	"extends": "@tsconfig/svelte/tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"moduleResolution": "bundler",
		"noEmit": true,
		"strict": true,
		"target": "ES2022",
		"module": "ESNext",
		"types": ["svelte", "vite/client"]
	},
	"include": ["src/**/*.ts", "src/**/*.svelte", "vite.config.ts", "svelte.config.js"]
}
