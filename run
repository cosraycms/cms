<?php

declare(strict_types=1);

require __DIR__ . '/vendor/autoload.php';

use Celemas\Cli\Runner;
use Cosray\Commands\InstallPanel;
use Cosray\Commands\RecreateDb;
use Cosray\Commands\RecreateSortIndex;
use Cosray\Commands\References;
use Cosray\Config;
use Cosray\MigrationFactory;
use Celemas\Container\Container;
use Celemas\Quma\Commands as QumaCommands;
use Celemas\Quma\Connection;
use Celemas\Quma\Delimiters;
use Celemas\Verba\Command\StatusCommand;
use Celemas\Verba\Command\SyncCommand;
use Celemas\Verba\Tool\Domain;
use Celemas\Verba\Tool\JavascriptScanner;
use Celemas\Verba\Tool\PhpScanner;

$env = static function (string $key, string $default): string {
	$value = getenv($key);

	return $value !== false && $value !== '' ? $value : $default;
};

$host = $env('COSRAY_DB_HOST', 'localhost');
$database = $env('COSRAY_DB_NAME', 'cosray');
$username = $env('COSRAY_DB_USER', 'cosray');
$password = $env('COSRAY_DB_PASSWORD', 'cosray');
$dsn = "pgsql:host={$host};dbname={$database};user={$username};password={$password}";

$config = new Config(__DIR__, ['db.dsn' => $dsn]);
$container = new Container();
$container->add($config::class, $config);

// Same namespace layout as Bootstrap::database(): `install` holds the schema
// snapshot (init + seed, run once on a fresh database via `--namespace
// install`), `default` the system update migrations. The seed bookkeeps all
// update migrations, so the default namespace only applies ones added later.
$conn = new Connection($dsn, __DIR__ . '/db/sql')
	->placeholders(Delimiters::comments(), $config->db->placeholders)
	->migrations([
		'install' => [__DIR__ . '/db/migrations/install'],
		'default' => [__DIR__ . '/db/migrations/update'],
	]);

$commands = QumaCommands::get($conn, migrationFactory: new MigrationFactory($container));
$commands->add(new InstallPanel($config));
$commands->add(new RecreateDb($database, $username, $password, $host));
$commands->add(new References($conn));
$commands->add(new RecreateSortIndex($conn));
// `db:titles` (Cosray\Commands\Titles) needs the booted app (node type
// registry + locales), so it is registered from an app's own commands.php
// where a Context/Cms are available — the library runner has no app nodes.

// i18n extraction. The `cosray` domain holds backend strings (PHP + Boiler
// views); the `panel` domain holds the SSR/Svelte panel strings and is the one
// shipped to the browser as an inline catalog. Both scan disjoint sources, so
// both claim the bare `__()` calls their own scanner finds. Schema-label
// extraction needs a booted registry and is registered from an app's commands.
$cosrayI18n = new Domain(
	name: 'cosray',
	dir: __DIR__ . '/lang',
	locales: ['de', 'en'],
	scanners: [new PhpScanner([__DIR__ . '/src', __DIR__ . '/panel/views'])],
	default: true,
);
$panelI18n = new Domain(
	name: 'panel',
	dir: __DIR__ . '/lang',
	locales: ['de', 'en'],
	scanners: [new JavascriptScanner([__DIR__ . '/panel/src'])],
	default: true,
);
$i18nDomains = [$cosrayI18n, $panelI18n];
$commands->add(new SyncCommand($i18nDomains));
$commands->add(new StatusCommand($i18nDomains));

$runner = new Runner($commands);

exit($runner->run());

// vim: ft=php
